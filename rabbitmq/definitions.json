{
  "rabbit_version": "4.1.0",
  "vhosts": [
    { "name": "/" }
  ],
  "exchanges": [
    {
      "name": "shop.notifications",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "shop.notifications.ui",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "shop.notifications",
      "vhost": "/",
      "destination": "shop.notifications.ui",
      "destination_type": "queue",
      "routing_key": "ui.#",
      "arguments": {}
    }
  ]
}

